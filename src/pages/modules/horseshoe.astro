---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// ── Quote data ──
const quoteEntries = await getCollection('horseshoe-quotes');
const alphaEntry = quoteEntries.find(e => e.data.side === 'alpha')!;
const buffoonEntry = quoteEntries.find(e => e.data.side === 'buffoon')!;
const alphaQuotes = (alphaEntry.body ?? '').split('\n').filter(l => l.trim().length > 0);
const buffoonQuotes = (buffoonEntry.body ?? '').split('\n').filter(l => l.trim().length > 0);

// ── Essay ──
const essayEntry = await getEntry('Articles', 'signal-noise-horseshoe');
const { Content: EssayContent } = await essayEntry!.render();
---

<BaseLayout title="Signal / Noise — Grappling Primitives">
  <div class="hs-page">

    <header class="hs-header">
      <p class="hs-eyebrow">Grappling Primitives</p>
      <h1 class="hs-title">Signal / Noise</h1>
      <p class="hs-sub">overdoing jokes and badassery</p>
    </header>

    <button id="deeplink-btn" class="hs-deeplink">Link</button>

    <div class="hs-stage">

      <!-- alpha quote zone -->
      <div id="zone-alpha" class="hs-quote-zone hs-quote-zone--alpha"></div>

      <!-- center panel -->
      <div class="hs-center">
        <svg viewBox="0 0 500 390" class="hs-svg">
          <defs>
            <linearGradient id="hs-grad" x1="0" y1="1" x2="0" y2="0">
              <stop offset="0%"   stop-color="#b71c1c"/>
              <stop offset="25%"  stop-color="#d32f2f"/>
              <stop offset="40%"  stop-color="#ef6c00"/>
              <stop offset="55%"  stop-color="#f9a825"/>
              <stop offset="70%"  stop-color="#66bb6a"/>
              <stop offset="85%"  stop-color="#43a047"/>
              <stop offset="100%" stop-color="#2e7d32"/>
            </linearGradient>
          </defs>
          <!-- horseshoe arc — single path with vertical gradient (red at bottom → green at top) -->
          <path d="M 185,313 A 130,130 0 0,1 120,200 A 130,130 0 0,1 185,87 A 130,130 0 0,1 315,87 A 130,130 0 0,1 380,200 A 130,130 0 0,1 315,313" stroke="url(#hs-grad)" stroke-width="40" fill="none" stroke-linecap="round"/>
          <!-- neighbor line -->
          <line x1="185" y1="340" x2="315" y2="340" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="4,3"/>
          <!-- labels -->
          <text x="250" y="18"  text-anchor="middle" font-size="16" font-family="'Courier New',Consolas,monospace" fill="rgba(229,231,235,0.6)">craft · signal</text>
          <text x="143" y="375" text-anchor="middle" font-size="15" font-family="'Courier New',Consolas,monospace" fill="rgba(229,231,235,0.45)">alpha bro</text>
          <text x="357" y="375" text-anchor="middle" font-size="15" font-family="'Courier New',Consolas,monospace" fill="rgba(229,231,235,0.45)">buffoon</text>
          <text x="250" y="363" text-anchor="middle" font-size="13" font-family="'Courier New',Consolas,monospace" fill="rgba(229,231,235,0.22)">extremes are neighbors</text>
          <!-- dot -->
          <circle id="hs-dot" cx="250" cy="70" r="10" fill="#050509" stroke="#2e7d32" stroke-width="3"/>
        </svg>

        <div class="hs-slider-row">
          <input type="range" id="hs-slider" min="0" max="100" value="50" step="1" aria-label="Signal-noise spectrum position">
          <div class="hs-slider-labels">
            <span>alpha extreme</span>
            <span>craft center</span>
            <span>buffoon extreme</span>
          </div>
        </div>

        <div class="hs-signal-row">
          <span class="hs-signal-label">signal</span>
          <div class="hs-signal-track">
            <div class="hs-signal-fill" id="hs-bar"></div>
          </div>
          <span class="hs-signal-pct" id="hs-pct">95%</span>
        </div>

      </div>

      <!-- buffoon quote zone -->
      <div id="zone-buffoon" class="hs-quote-zone hs-quote-zone--buffoon"></div>

    </div>

    <details class="tldr">
      <summary class="tldr__toggle">The Grappling Horseshoe — full essay</summary>
      <div class="tldr__body article-prose">
        <EssayContent />
      </div>
    </details>

  </div>
</BaseLayout>

<script define:vars={{ alphaQuotes, buffoonQuotes }}>
(function () {
  'use strict';

  const ZONES = [
    { max: 15,  label: 'Alpha extreme \u2014 performance crowding signal', color: '#c62828',
      desc: 'Every roll is a proving ground. Training partners are prey. The mat serves the persona, not the other way around.' },
    { max: 35,  label: 'Alpha register \u2014 signal dominant',            color: '#ef6c00',
      desc: 'Real-politik edge that checks complacency. The tough register in service of the craft \u2014 not the craft in service of the idiom.' },
    { max: 65,  label: 'Craft center',                                     color: '#2e7d32',
      desc: 'The thing being studied is the point. Humor, edge, intensity \u2014 held in reserve, deployed with intent. Idiom serves the work.' },
    { max: 85,  label: 'Levity register \u2014 signal dominant',           color: '#ef6c00',
      desc: 'Humor makes the room easier to be in. Self-deprecating acknowledgment of the absurdity. Signal intact \u2014 the joke is not the session.' },
    { max: 100, label: 'Buffoon extreme \u2014 performance crowding signal', color: '#c62828',
      desc: 'Every position is a bit. Every tap is a performance. The mat is a stage. Two people rolling are the audience. Signal gone.' },
  ];

  const sl  = document.getElementById('hs-slider');
  const dot = document.getElementById('hs-dot');
  const bar = document.getElementById('hs-bar');
  const pct = document.getElementById('hs-pct');
  const zA  = document.getElementById('zone-alpha');
  const zB  = document.getElementById('zone-buffoon');

  var CRAFT_Q = [
    'Turn the resistance up but controlled',
    "Don't take it too seriously, relax",
    'Be aware of how you got tapped',
    'Give them challenges, not injuries',
  ];

  let aTimer = null, bTimer = null, cTimer = null;
  let aUsed  = [],   bUsed  = [], cUsed = [];

  function pick(arr, used) {
    if (used.length >= arr.length) used.length = 0;
    const rem = arr.filter(function (q) { return used.indexOf(q) < 0; });
    const q   = rem[Math.floor(Math.random() * rem.length)];
    used.push(q);
    return q;
  }

  // ── Ordered slot system for quote positioning ──
  // Divide vertical space into slots; cycle through them in order
  // with a random offset so consecutive quotes are never adjacent.
  var SLOTS = [0, 16, 32, 48, 64];
  var aSlotIdx = 0, bSlotIdx = 0, cSlotIdx = 0;

  function nextSlot(current) {
    // jump 2-3 slots ahead (wrapping) so consecutive quotes are spaced apart
    var jump = 2 + Math.floor(Math.random() * 2); // 2 or 3
    return (current + jump) % SLOTS.length;
  }

  function spawn(zone, text, cls) {
    var slotIdx;
    if (cls === 'alpha')      { slotIdx = aSlotIdx; aSlotIdx = nextSlot(aSlotIdx); }
    else if (cls === 'craft') { slotIdx = cSlotIdx; cSlotIdx = nextSlot(cSlotIdx); }
    else                      { slotIdx = bSlotIdx; bSlotIdx = nextSlot(bSlotIdx); }

    var baseTop = SLOTS[slotIdx];
    // small jitter within the slot (±4%) to avoid mechanical feel
    var jitter = Math.floor(Math.random() * 8) - 4;
    var top = Math.max(0, Math.min(72, baseTop + jitter));

    const el       = document.createElement('div');
    el.className   = 'hs-q-item hs-q-item--' + cls;
    el.textContent = '\u201C' + text + '\u201D';
    el.style.top   = top + '%';
    el.style.opacity = '0';
    zone.appendChild(el);

    const FI = 350, STAY = 2200, FO = 800, total = FI + STAY + FO;
    let t0 = null;

    (function frame(ts) {
      if (!t0) t0 = ts;
      const e = ts - t0;
      let op;
      if      (e < FI)          op = e / FI;
      else if (e < FI + STAY)   op = 1;
      else if (e < total)       op = 1 - (e - FI - STAY) / FO;
      else { el.remove(); return; }
      el.style.opacity = op.toFixed(3);
      requestAnimationFrame(frame);
    })(performance.now());
  }

  function startAlpha(fast) {
    if (aTimer) return;
    var rate = fast ? 1200 : 2400;
    spawn(zA, pick(alphaQuotes, aUsed), 'alpha');
    aTimer = setInterval(function () { spawn(zA, pick(alphaQuotes, aUsed), 'alpha'); }, rate);
  }
  function stopAlpha() { if (aTimer) { clearInterval(aTimer); aTimer = null; } }

  function startBuff(fast) {
    if (bTimer) return;
    var rate = fast ? 1200 : 2400;
    spawn(zB, pick(buffoonQuotes, bUsed), 'buffoon');
    bTimer = setInterval(function () { spawn(zB, pick(buffoonQuotes, bUsed), 'buffoon'); }, rate);
  }
  function stopBuff() { if (bTimer) { clearInterval(bTimer); bTimer = null; } }

  function startCraft() {
    if (cTimer) return;
    // alternate sides for craft quotes
    var craftSide = 0;
    function spawnCraft() {
      var zone = craftSide % 2 === 0 ? zA : zB;
      spawn(zone, pick(CRAFT_Q, cUsed), 'craft');
      craftSide++;
    }
    spawnCraft();
    cTimer = setInterval(spawnCraft, 3200);
  }
  function stopCraft() { if (cTimer) { clearInterval(cTimer); cTimer = null; } }

  function updateQuotes(v) {
    // orange/red zones: alpha or buffoon quotes
    if (v <= 25) {
      stopBuff(); stopCraft();
      if (aTimer && ((v <= 15) !== prevAlphaFast)) { stopAlpha(); }
      startAlpha(v <= 15);
      prevAlphaFast = v <= 15;
    } else if (v >= 75) {
      stopAlpha(); stopCraft();
      if (bTimer && ((v >= 85) !== prevBuffFast)) { stopBuff(); }
      startBuff(v >= 85);
      prevBuffFast = v >= 85;
    } else if (v >= 36 && v <= 64) {
      // green zone: positive craft quotes
      stopAlpha(); stopBuff();
      startCraft();
    } else {
      // transition zones (26-35, 65-74): quiet
      stopAlpha(); stopBuff(); stopCraft();
    }
  }

  var prevAlphaFast = false, prevBuffFast = false;

  function update(v) {
    var t = v / 100;
    var a = (120 + t * 300) * Math.PI / 180;
    dot.setAttribute('cx', (250 + 130 * Math.cos(a)).toFixed(2));
    dot.setAttribute('cy', (200 + 130 * Math.sin(a)).toFixed(2));

    var z = ZONES.find(function (x) { return v <= x.max; }) || ZONES[4];
    dot.setAttribute('stroke', z.color);

    var sig = Math.round(20 + 75 * (1 - Math.pow(2 * v / 100 - 1, 2)));
    bar.style.width      = sig + '%';
    bar.style.background = z.color;
    pct.textContent      = sig + '%';

    sl.style.setProperty('--thumb-color', z.color);
    updateQuotes(v);
  }

  // ── Autoplay ──
  var idleTimeout = null;
  var autoplayRAF = null;
  var autoplayActive = false;
  var autoTarget = null;
  var autoPauseUntil = 0;

  function pickAutoTarget() {
    // pick a random position, biased toward extremes for visual interest
    var r = Math.random();
    if (r < 0.35) return Math.floor(Math.random() * 30);        // left side
    else if (r < 0.7) return 70 + Math.floor(Math.random() * 30); // right side
    else return 25 + Math.floor(Math.random() * 50);              // middle
  }

  function autoplayStep(ts) {
    if (!autoplayActive) return;
    if (ts < autoPauseUntil) {
      autoplayRAF = requestAnimationFrame(autoplayStep);
      return;
    }
    var current = +sl.value;
    if (autoTarget === null || Math.abs(current - autoTarget) < 1) {
      // arrived — pause 2-4s then pick new target
      autoTarget = pickAutoTarget();
      autoPauseUntil = ts + 2000 + Math.random() * 2000;
      autoplayRAF = requestAnimationFrame(autoplayStep);
      return;
    }
    // move toward target slowly (~0.3 units per frame at 60fps)
    var step = autoTarget > current ? 0.3 : -0.3;
    var next = Math.round(current + step);
    if (next === current) next = current + (step > 0 ? 1 : -1);
    next = Math.max(0, Math.min(100, next));
    sl.value = next;
    update(next);
    autoplayRAF = requestAnimationFrame(autoplayStep);
  }

  function startAutoplay() {
    if (autoplayActive) return;
    autoplayActive = true;
    autoTarget = null;
    autoPauseUntil = 0;
    autoplayRAF = requestAnimationFrame(autoplayStep);
  }

  function stopAutoplay() {
    autoplayActive = false;
    if (autoplayRAF) { cancelAnimationFrame(autoplayRAF); autoplayRAF = null; }
  }

  function resetIdleTimer() {
    if (idleTimeout) clearTimeout(idleTimeout);
    idleTimeout = setTimeout(startAutoplay, 10000);
  }

  sl.addEventListener('input', function (e) {
    stopAutoplay();
    update(+e.target.value);
    resetIdleTimer();
  });

  // start with autoplay
  update(50);
  startAutoplay();

  var dlBtn = document.getElementById('deeplink-btn');
  if (dlBtn) {
    dlBtn.addEventListener('click', function () {
      navigator.clipboard.writeText(window.location.href).then(function () {
        dlBtn.textContent = 'Copied!';
        setTimeout(function () { dlBtn.textContent = 'Link'; }, 1500);
      });
    });
  }
})();
</script>

<style is:global>
  .hs-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 48px 16px 64px;
  }

  .hs-header {
    text-align: center;
    margin-bottom: 48px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .hs-eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 12px;
  }

  .hs-title {
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--text-primary);
    margin-bottom: 14px;
    text-shadow: 0 0 12px #2e7d3266;
  }

  .hs-sub {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.7;
    font-style: italic;
  }

  .hs-deeplink {
    position: fixed;
    top: 12px;
    right: 12px;
    z-index: 60;
    font-family: 'Courier New', Consolas, Monaco, monospace;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 3px;
    cursor: pointer;
    border: 1px solid #21262d;
    background: transparent;
    color: #6b7280;
    transition: all 0.15s;
  }
  .hs-deeplink:hover {
    border-color: rgba(0,212,255,0.4);
    color: #00d4ff;
  }

  /* ── main layout ── */
  .hs-stage {
    display: grid;
    grid-template-columns: 1fr minmax(0, 480px) 1fr;
    gap: 0;
    width: 100%;
    align-items: start;
  }

  /* ── quote zones ── */
  .hs-quote-zone {
    position: relative;
    min-height: 340px;
    overflow: hidden;
    padding: 0 8px;
  }

  .hs-quote-zone--alpha  { padding-right: 12px; }
  .hs-quote-zone--buffoon { padding-left: 12px; }

  .hs-q-item {
    position: absolute;
    font-size: var(--text-xs);
    line-height: 1.55;
    font-style: italic;
    opacity: 0;
    max-width: 100%;
    pointer-events: none;
  }

  .hs-q-item--alpha   { color: #d32f2f; text-align: right; right: 0; }
  .hs-q-item--buffoon { color: #ef6c00; text-align: left; left: 0; }
  .hs-q-item--craft   { color: #43a047; }

  /* ── SVG panel ── */
  .hs-svg { width: 100%; display: block; }

  /* ── slider ── */
  .hs-slider-row {
    padding: 0 2rem;
    margin: 4px 0 12px;
  }

  .hs-slider-row input[type=range] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 3px;
    background: linear-gradient(to right, #b71c1c 0%, #c62828 10%, #ef6c00 25%, #f9a825 35%, #66bb6a 42%, #2e7d32 50%, #66bb6a 58%, #f9a825 65%, #ef6c00 75%, #c62828 90%, #b71c1c 100%);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
    opacity: 0.7;
  }

  .hs-slider-row input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #050509;
    border: 2.5px solid var(--thumb-color, #2e7d32);
    cursor: grab;
    transition: border-color 0.15s;
  }

  .hs-slider-row input[type=range]:active::-webkit-slider-thumb { cursor: grabbing; }

  .hs-slider-row input[type=range]::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #050509;
    border: 2.5px solid var(--thumb-color, #2e7d32);
    cursor: grab;
  }

  .hs-slider-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 6px;
    font-size: var(--text-sm);
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  /* ── signal bar ── */
  .hs-signal-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 1rem;
    margin-bottom: 16px;
  }

  .hs-signal-label {
    font-size: var(--text-sm);
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    min-width: 36px;
  }

  .hs-signal-track {
    flex: 1;
    height: 4px;
    background: rgba(255,255,255,0.07);
    border-radius: 2px;
    overflow: hidden;
  }

  .hs-signal-fill {
    height: 100%;
    width: 95%;
    background: #2e7d32;
    border-radius: 2px;
    transition: width 0.15s ease, background 0.15s ease;
  }

  .hs-signal-pct {
    font-size: var(--text-base);
    color: var(--text-muted);
    min-width: 30px;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }


  /* ── tolkien footer ── */
  .hs-tolkien {
    margin-top: 52px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
    border-top: 1px solid var(--border);
    padding-top: 28px;
  }

  .hs-tolkien blockquote {
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 8px;
  }

  .hs-tolkien cite {
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }

  /* ── responsive ── */
  @media (max-width: 600px) {
    .hs-stage { grid-template-columns: 1fr; }
    .hs-quote-zone { display: none; }
    .hs-header { margin-bottom: 32px; }
  }
</style>
