}

.mismatch-detail {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 16px 20px;
  font-size: 0.85rem;
  color: var(--text-muted);
  min-height: 60px;
  transition: border-color 0.3s;
