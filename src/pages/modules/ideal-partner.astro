      { icon: imgBase + 'icon_400x_0007_MildMismatch.png', type: 'mild',
        en: { title: 'Mild Mismatch', desc: 'You\'re pushing, partner is flowing. They feel bulldozed; you don\'t improve because there\'s no resistance to test against.' },
        ja: { title: '\u8EFD\u5EA6\u30DF\u30B9\u30DE\u30C3\u30C1', desc: '\u3042\u306A\u305F\u306F\u62BC\u3057\u3001\u30D1\u30FC\u30C8\u30CA\u30FC\u306F\u30D5\u30ED\u30FC\u3002\u76F8\u624B\u306F\u5727\u5012\u3055\u308C\u3001\u3042\u306A\u305F\u306F\u30C6\u30B9\u30C8\u3059\u308B\u62B5\u6297\u304C\u306A\u304F\u6210\u9577\u3067\u304D\u306A\u3044\u3002' }
