            <div class="tradeoff-section">
              <div class="tradeoff-section-label costs">✦ ${ja ? '失うもの' : 'What it costs'}</div>
              <ul class="tradeoff-list">${d.costs.map(c => `<li>${c}</li>`).join('')}</ul>
            </div>
            <div class="tradeoff-section">
              <div class="tradeoff-section-label best">✦ ${ja ? '最適な場面' : 'Best for'}</div>
              <p style="font-size:0.8rem;color:var(--cyan-dim);margin:0;">${d.best}</p>
            </div>
          </div>
        </div>`;
    });

    html += '</div>';
    container.innerHTML = html;

    // Toggle expand/collapse
    container.querySelectorAll('.tradeoff-card').forEach(el => {
      el.addEventListener('click', () => {
        el.classList.toggle('expanded');
      });
    });
  }

  render();

  const langBtn = document.getElementById('lang-toggle');
  if (langBtn) langBtn.addEventListener('click', () => setTimeout(render, 10));
}

// ═══ Initialize ═══
initIntensityViz('viz-intensity');
initMismatchViz('viz-mismatch');
initDriftViz('viz-drift');
initTradeoffsViz('viz-tradeoffs');
</script>
