// ═══ Mind Overstimulation Animation ═══
(function initOverstimAnim() {
  const label = document.getElementById('overstim-label');
  const pct = document.getElementById('overstim-pct');
  const fill = document.getElementById('overstim-fill');
  const blocks = document.getElementById('overstim-blocks');
  if (!label || !pct || !fill) return;

  const stages = [
    { threshold: 0,   text: 'stimulated',      color: '#E5E7EB' },
    { threshold: 30,  text: 'overstimulated',   color: '#00d4ff' },
    { threshold: 60,  text: 'anxious...',        color: '#FBBF24' },
    { threshold: 90,  text: 'fatigued...',       color: '#F97316' },
    { threshold: 120, text: 'exhausted...',      color: '#F87171' },
    { threshold: 150, text: 'UNSTABLE!',         color: '#FF3333' }
  ];

  let running = false;
  let animId = null;

  function getStage(v) {
    let s = stages[0];
    for (const st of stages) {
      if (v >= st.threshold) s = st;
    }
    return s;
  }

  function buildBlocks(v, maxV) {
    const total = 14;
    const filled = Math.round((Math.min(v, maxV) / maxV) * total);
    return '▣'.repeat(filled) + '□'.repeat(total - filled);
  }

  function cycle() {
    const maxPct = 100 + Math.floor(Math.random() * 81); // 100–180%
    let current = 0;
    const step = 1.2;

    function tick() {
      current += step;
      if (current > maxPct) {
        // Hold at peak — longer pause if we reached UNSTABLE! territory
        const peakPause = maxPct >= 150 ? 4000 : 1200;
        setTimeout(() => {
          // Quick fade down
          let down = maxPct;
          function fadeDown() {
            down -= 4;
            if (down <= 0) {
              down = 0;
              update(0, maxPct);
              setTimeout(cycle, 800);
              return;
            }
            update(down, maxPct);
            requestAnimationFrame(fadeDown);
          }
          fadeDown();
        }, peakPause);
        return;
      }
      update(current, maxPct);
      animId = requestAnimationFrame(tick);
    }

    function update(v, maxV) {
      const stage = getStage(v);
      const displayPct = Math.round(v);
      pct.textContent = displayPct + '%';
      pct.style.color = stage.color;
      pct.style.textShadow = `0 0 12px ${stage.color}66`;
      label.textContent = stage.text;
      label.style.color = stage.color;
      const barWidth = Math.min((v / maxV) * 100, 100);
      fill.style.width = barWidth + '%';
      fill.style.background = stage.color;
      if (v > 100) {
        fill.style.boxShadow = `0 0 8px ${stage.color}88, 0 0 16px ${stage.color}44`;
      } else {
        fill.style.boxShadow = 'none';
      }
      blocks.textContent = buildBlocks(v, maxV);
      blocks.style.color = stage.color;
    }

    tick();
  }

  // Start when Act 0 is visible
  const section = document.getElementById('act-0');
  if (section) {
    const obs = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting && !running) {
        running = true;
        setTimeout(cycle, 600);
      }
    }, { threshold: 0.3 });
    obs.observe(section);
  }
})();

// ═══ Body Decline Animation ═══
(function initBodyDeclineAnim() {
  const canvas = document.getElementById('body-decline-canvas');
  const label = document.getElementById('body-decline-label');
  if (!canvas || !label) return;

  const ctx = canvas.getContext('2d');
  let running = false;

  function resize() {
    const rect = canvas.parentElement.getBoundingClientRect();
    const w = Math.min(rect.width, 200);
    const dpr = window.devicePixelRatio || 1;
    canvas.width = w * dpr;
    canvas.height = 80 * dpr;
    canvas.style.width = w + 'px';
    canvas.style.height = '80px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  const lines = [
    { color: '#34D399', label: 'Mobility',  startY: 0.15, endY: 0.85, noise: 0.04 },
    { color: '#4C8DFF', label: 'Strength',  startY: 0.10, endY: 0.90, noise: 0.05 },
    { color: '#F97316', label: 'Energy',    startY: 0.20, endY: 0.80, noise: 0.06 }
  ];

  const stages = [
    { threshold: 0,    text: 'Under-stimulated', color: '#9CA3AF' },
    { threshold: 0.33, text: 'Weakening...',      color: '#FBBF24' },
    { threshold: 0.66, text: 'Atrophying...',      color: '#F87171' }
  ];

  function getStage(t) {
    let s = stages[0];
    for (const st of stages) {
      if (t >= st.threshold) s = st;
    }
    return s;
  }

  // Seeded noise for consistent wiggles
  const seeds = lines.map(() => Array.from({length: 50}, () => Math.random() * 2 - 1));

  function draw(progress) {
    const w = canvas.width / (window.devicePixelRatio || 1);
    const h = canvas.height / (window.devicePixelRatio || 1);
    const pad = { top: 4, bottom: 4, left: 4, right: 4 };
    const pw = w - pad.left - pad.right;
    const ph = h - pad.top - pad.bottom;

    ctx.clearRect(0, 0, w, h);

    // Faint grid lines
    ctx.strokeStyle = '#1C1F2644';
    ctx.lineWidth = 0.5;
    for (let y = 0.25; y < 1; y += 0.25) {
      ctx.beginPath();
      ctx.moveTo(pad.left, pad.top + ph * y);
      ctx.lineTo(w - pad.right, pad.top + ph * y);
      ctx.stroke();
    }

    // Draw each declining line
    lines.forEach((line, li) => {
      ctx.strokeStyle = line.color;
      ctx.lineWidth = 2;
      ctx.lineJoin = 'round';
      ctx.lineCap = 'round';
      ctx.beginPath();
      const steps = 48;
      let started = false;
      for (let i = 0; i <= steps; i++) {
        const t = i / steps;
        if (t > progress) break;
        const baseY = line.startY + (line.endY - line.startY) * t;
        const noise = seeds[li][i % 50] * line.noise * (0.5 + t * 0.5);
        const x = pad.left + t * pw;
        const y = pad.top + (baseY + noise) * ph;
        if (!started) { ctx.moveTo(x, y); started = true; }
        else ctx.lineTo(x, y);
      }
      ctx.stroke();

      // Dot at current position
      if (progress > 0) {
        const t = Math.min(progress, 1);
        const baseY = line.startY + (line.endY - line.startY) * t;
        const noise = seeds[li][Math.floor(t * steps) % 50] * line.noise * (0.5 + t * 0.5);
        const x = pad.left + t * pw;
        const y = pad.top + (baseY + noise) * ph;
        ctx.fillStyle = line.color;
        ctx.beginPath();
        ctx.arc(x, y, 3, 0, Math.PI * 2);
        ctx.fill();
      }
    });

    // Update label
    const stage = getStage(progress);
    label.textContent = stage.text;
    label.style.color = stage.color;
  }

  function cycle() {
    let progress = 0;
    const speed = 0.005;

    function tick() {
      progress += speed;
      if (progress >= 1) {
        progress = 1;
        draw(progress);
        // Pause 10 seconds at full decline, then restart
        setTimeout(() => {
          progress = 0;
          draw(0);
          setTimeout(cycle, 800);
        }, 10000);
        return;
      }
      draw(progress);
      requestAnimationFrame(tick);
    }

    tick();
  }

  // Start when Act 0 is visible
  const section = document.getElementById('act-0');
  if (section) {
    const obs = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting && !running) {
        running = true;
        resize();
        draw(0);
        setTimeout(cycle, 600);
      }
    }, { threshold: 0.3 });
    obs.observe(section);
  }

  window.addEventListener('resize', () => { resize(); });
  resize();
  draw(0);
})();

