<script is:inline>

// ═══ Scroll Reveal + Deep Link Hash Tracking ═══
(function() {
  const acts = document.querySelectorAll('.act');
  let currentAct = null;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        const actId = e.target.id;
        if (actId && actId !== currentAct) {
          currentAct = actId;
          history.replaceState(null, '', location.pathname + location.search + '#' + actId);
        }
      }
    });
  }, { threshold: 0.15 });
  acts.forEach((a) => observer.observe(a));

  const hash = location.hash.replace('#', '');
  if (hash) {
    const target = document.getElementById(hash);
    if (target) {
      setTimeout(() => {
        target.scrollIntoView({ behavior: 'smooth' });
        target.classList.add('visible');
      }, 200);
    }
  }
})();

// ═══ Deep Link Button ═══
(function() {
  const btn = document.getElementById('deeplink-btn');
  if (!btn) return;
  btn.addEventListener('click', () => {
    navigator.clipboard.writeText(location.href).then(() => {
      btn.textContent = 'Copied!';
      btn.style.color = '#00d4ff';
      btn.style.borderColor = 'rgba(0,212,255,0.4)';
      setTimeout(() => {
        btn.textContent = 'Link';
        btn.style.color = '';
        btn.style.borderColor = '';
      }, 1500);
    });
  });
})();

// ═══ Language Toggle ═══
(function() {
  const btn = document.getElementById('lang-toggle');
  if (!btn) return;
  const labels = btn.querySelectorAll('.lang-label');
  let lang = 'en';
  btn.addEventListener('click', () => {
    lang = lang === 'en' ? 'ja' : 'en';
    document.body.classList.toggle('lang-ja', lang === 'ja');
    labels.forEach((l) => {
      if ((lang === 'en' && l.textContent === 'EN') || (lang === 'ja' && l.textContent === 'JP')) {
        l.setAttribute('data-active', '');
      } else {
        l.removeAttribute('data-active');
      }
    });
  });
})();

// ═══ Modal System ═══
(function() {
  function openModal(id) {
    const m = document.getElementById(id);
    if (m) m.classList.add('active');
  }
  function closeModal(m) {
    m.classList.remove('active');
  }

  // Open buttons
  const btnKodokan = document.getElementById('btn-kodokan');
  const btnKuzushi = document.getElementById('btn-kuzushi-xyz');
  if (btnKodokan) btnKodokan.addEventListener('click', () => openModal('modal-kodokan'));
  if (btnKuzushi) btnKuzushi.addEventListener('click', () => openModal('modal-kuzushi-xyz'));

  // Close buttons
  document.querySelectorAll('.modal-close').forEach(btn => {
    btn.addEventListener('click', () => {
      const overlay = btn.closest('.modal-overlay');
      if (overlay) closeModal(overlay);
    });
  });

  // Click outside
  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeModal(overlay);
    });
  });

  // Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.modal-overlay.active').forEach(closeModal);
    }
  });
})();

