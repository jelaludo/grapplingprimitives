    line-height: 1.6;
    opacity: 0;
    transition: opacity 0.3s;
    max-width: 58ch;
    font-family: inherit;
  }
  .fr-threshold-alert.visible { opacity: 1; }

  /* ── Tab 2: Research — Section Animation ─────────────────────────────────── */
  #tab-research .fr-section { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  #tab-research .fr-section.visible { opacity: 1; transform: none; }

  /* Hero */
  .fr-hero { padding: 4rem 8vw; border-bottom: 1px solid var(--fr-border); }
  .fr-hero-label { font-size: var(--text-xs); color: var(--fr-accent); text-transform: uppercase; letter-spacing: 0.18em; margin-bottom: 1.5rem; }
  .fr-hero h1 { font-size: clamp(2.5rem, 6vw, 5rem); color: var(--fr-text); line-height: 1.05; margin-bottom: 1rem; max-width: 14ch; }
  .fr-hero h1 em { color: var(--fr-cyan); font-style: italic; }
  .fr-hero-meta { font-size: var(--text-xs); color: var(--fr-dim); letter-spacing: 0.05em; }

  /* Section nav */
  .fr-section-nav { display: flex; overflow-x: auto; border-bottom: 1px solid var(--fr-border); }
  .fr-section-nav a { color: var(--fr-dim); text-decoration: none; font-size: var(--text-xs); letter-spacing: 0.08em; padding: 0 1.1rem; height: 40px; display: flex; align-items: center; border-right: 1px solid var(--fr-border); white-space: nowrap; transition: color 0.2s; text-transform: uppercase; }
  .fr-section-nav a:first-child { border-left: 1px solid var(--fr-border); }
  .fr-section-nav a:hover { color: var(--fr-accent); }

  /* Timeline */
  .fr-timeline { position: relative; padding-left: 2rem; }
  .fr-timeline::before { content: ''; position: absolute; left: 0; top: 0.6rem; bottom: 0.6rem; width: 1px; background: linear-gradient(to bottom, var(--fr-dim), transparent); }
  .fr-timeline-item { position: relative; margin-bottom: 2rem; padding-left: 1.5rem; }
  .fr-timeline-item::before { content: ''; position: absolute; left: -2rem; top: 0.55em; width: 8px; height: 8px; border-radius: 50%; background: var(--fr-dim); border: 1px solid var(--fr-accent); }
  .fr-timeline-item.key::before { background: var(--fr-accent); box-shadow: 0 0 10px rgba(76,141,255,0.4); }
  .fr-year { font-size: var(--text-xs); color: var(--fr-accent); letter-spacing: 0.08em; margin-bottom: 0.3rem; }
  .fr-timeline-item h4 { font-size: var(--text-sm); color: var(--fr-text); margin-bottom: 0.3rem; }
  .fr-timeline-item p { font-size: var(--text-xs); color: var(--fr-muted); margin-bottom: 0; }

  /* Diagram wrap */
  .fr-diagram-wrap { background: var(--fr-surface); border: 1px solid var(--fr-border); border-radius: 2px; padding: 2rem; position: relative; }
  .fr-diagram-title { font-size: var(--text-xs); color: var(--fr-dim); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 1.2rem; text-align: center; }
  #channelCanvas { display: block; width: 100%; cursor: pointer; }
  .fr-channel-info { margin-top: 1.2rem; min-height: 4rem; padding: 1rem 1.2rem; background: rgba(14,16,20,0.8); border-left: 2px solid var(--fr-accent); font-size: var(--text-sm); transition: opacity 0.25s; }
  .fr-channel-info .ch-name { font-size: var(--text-xs); color: var(--fr-accent); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.3rem; }
  .fr-diagram-hint { font-size: var(--text-xs); color: var(--fr-dim); text-align: center; margin-top: 0.8rem; letter-spacing: 0.06em; }
  .fr-axis-labels { display: flex; justify-content: space-between; font-size: var(--text-xs); color: var(--fr-muted); margin-top: 0.4rem; padding: 0 0.2rem; }

  /* Tab toggles (within research tab) */
  .fr-tab-row { display: flex; gap: 0; border: 1px solid var(--fr-border); overflow: hidden; margin-bottom: 2rem; flex-wrap: wrap; }
  .fr-tab-btn { flex: 1; padding: 0.7rem 1rem; background: none; border: none; border-right: 1px solid var(--fr-border); color: var(--fr-dim); font-family: 'Source Code Pro', 'Courier New', monospace; font-size: var(--text-xs); letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; transition: background 0.2s, color 0.2s; }
  .fr-tab-btn:last-child { border-right: none; }
  .fr-tab-btn:hover { background: rgba(14,16,20,0.8); color: var(--fr-muted); }
  .fr-tab-btn.active { background: rgba(76,141,255,0.1); color: var(--fr-accent); }
  .fr-tab-content { display: none; }
  .fr-tab-content.active { display: block; }

  /* Pull quote */
  .fr-pull-quote { border-left: 3px solid var(--fr-accent); margin: 2rem 0; padding: 1rem 1.5rem; font-style: italic; font-size: clamp(1rem, 2vw, 1.25rem); color: var(--fr-text); line-height: 1.5; }
  .fr-pull-quote cite { display: block; margin-top: 0.6rem; font-size: var(--text-xs); font-style: normal; color: var(--fr-dim); letter-spacing: 0.05em; }

  /* Vis cards */
  .fr-vis-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2rem; align-items: start; }
  @media (max-width: 900px) { .fr-vis-grid { grid-template-columns: 1fr; } }
  .fr-vis-card { background: var(--fr-surface); border: 1px solid var(--fr-border); padding: 1.2rem 1.4rem 1rem; transition: border-color 0.2s; }
  .fr-vis-card:hover { border-color: var(--fr-accent); }
  .fr-vis-label { font-size: var(--text-xs); color: var(--fr-accent); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.4rem; }
  .fr-vis-caption { font-size: var(--text-xs); color: var(--fr-muted); margin-bottom: 0.9rem; font-style: italic; }
  .fr-vis-tag { font-size: var(--text-xs); color: var(--fr-dim); margin-right: 0.4rem; font-style: normal; }
  .fr-vis-note { font-size: var(--text-xs); color: var(--fr-muted); margin-top: 0.7rem; font-style: italic; border-top: 1px solid var(--fr-border); padding-top: 0.6rem; line-height: 1.5; }

  /* Method box */
  .fr-method-box { background: var(--fr-surface); border: 1px solid rgba(76,141,255,0.2); padding: 2rem; margin: 2rem 0; position: relative; }
  .fr-method-box::before { content: 'METHOD'; position: absolute; top: -0.7rem; left: 1.5rem; font-size: var(--text-xs); letter-spacing: 0.12em; color: var(--fr-accent); background: var(--fr-surface); padding: 0 0.5rem; }
  .fr-method-box h4 { font-size: var(--text-base); color: var(--fr-text); margin-bottom: 0.8rem; }
  .fr-method-box p { font-size: var(--text-sm); }

  /* Brain diagram */
  .fr-brain-diagram { background: var(--fr-surface); border: 1px solid var(--fr-border); padding: 2rem; display: flex; align-items: center; gap: 2rem; margin: 2rem 0; flex-wrap: wrap; }
  .fr-brain-svg-wrap { flex: 0 0 140px; }
  .fr-brain-text { flex: 1; min-width: 200px; font-size: var(--text-sm); }

  /* Stat callouts */
  .fr-stat-callout { display: flex; gap: 2rem; margin: 2rem 0; flex-wrap: wrap; }
  .fr-stat-item { flex: 1; min-width: 140px; border-left: 2px solid var(--fr-accent); padding-left: 1rem; }
  .fr-stat-num { font-size: clamp(2rem, 4vw, 3rem); color: var(--fr-accent); line-height: 1; }
  .fr-stat-label { font-size: var(--text-xs); color: var(--fr-muted); letter-spacing: 0.06em; margin-top: 0.3rem; }

  /* Evidence cards */
  .fr-evidence-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.2rem; margin-top: 2rem; }
  .fr-evidence-card { background: var(--fr-surface); border: 1px solid var(--fr-border); padding: 1.4rem; position: relative; transition: border-color 0.2s, background 0.2s; }
  .fr-evidence-card:hover { border-color: var(--fr-accent); background: rgba(14,16,20,0.8); }
  .fr-evidence-card h4 { font-size: var(--text-base); color: var(--fr-text); margin-bottom: 0.5rem; }
  .fr-evidence-card p { font-size: var(--text-sm); color: var(--fr-muted); margin-bottom: 0.8rem; }
  .fr-status { font-size: var(--text-xs); letter-spacing: 0.1em; text-transform: uppercase; padding: 0.2rem 0.6rem; border-radius: 1px; margin-bottom: 0.8rem; display: inline-block; }
  .fr-status.replicated { background: rgba(52,211,153,0.15); color: #34D399; border: 1px solid rgba(52,211,153,0.3); }
  .fr-status.partial { background: rgba(245,158,11,0.12); color: #F59E0B; border: 1px solid rgba(245,158,11,0.25); }
  .fr-status.failed { background: rgba(239,68,68,0.12); color: #EF4444; border: 1px solid rgba(239,68,68,0.25); }
  .fr-status.open { background: rgba(76,141,255,0.12); color: #4C8DFF; border: 1px solid rgba(76,141,255,0.25); }

  /* Verdict table */
  .fr-verdict-table { width: 100%; border-collapse: collapse; margin: 2rem 0; font-size: var(--text-sm); }
  .fr-verdict-table th { font-size: var(--text-xs); letter-spacing: 0.1em; color: var(--fr-accent); text-align: left; padding: 0.8rem 1rem; border-bottom: 1px solid rgba(76,141,255,0.35); text-transform: uppercase; }
  .fr-verdict-table td { padding: 0.9rem 1rem; border-bottom: 1px solid var(--fr-border); color: var(--fr-muted); vertical-align: top; }
  .fr-verdict-table tr:last-child td { border-bottom: none; }
  .fr-verdict-table td:first-child { color: var(--fr-text); font-style: italic; }
  .fr-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 0.5rem; vertical-align: middle; }
  .fr-dot.yes { background: #34D399; }
  .fr-dot.partial { background: #F59E0B; }
  .fr-dot.no { background: #EF4444; }

  /* Paper list */
  .fr-paper-list { margin-top: 2rem; border: 1px solid var(--fr-border); overflow: hidden; }
  .fr-paper-item { padding: 1.2rem 1.4rem; border-bottom: 1px solid var(--fr-border); display: grid; grid-template-columns: auto 1fr auto; gap: 1rem; align-items: start; transition: background 0.2s; }
  .fr-paper-item:last-child { border-bottom: none; }
  .fr-paper-item:hover { background: rgba(14,16,20,0.8); }
  .fr-paper-num { font-size: var(--text-xs); color: var(--fr-dim); padding-top: 0.15em; white-space: nowrap; }
  .fr-paper-title { font-size: var(--text-sm); color: var(--fr-text); font-style: italic; display: block; margin-bottom: 0.2rem; }
  .fr-paper-meta { font-size: var(--text-xs); color: var(--fr-muted); }
  .fr-paper-link { font-size: var(--text-xs); color: var(--fr-accent); text-decoration: none; padding: 0.25rem 0.6rem; border: 1px solid var(--fr-dim); white-space: nowrap; transition: background 0.2s, color 0.2s; }
  .fr-paper-link:hover { background: var(--fr-accent); color: var(--fr-bg); }
</style>

<script>
  /* ── Tab switching ────────────────────────────────────────────────────────── */
  const tabs = document.querySelectorAll('.fr-tab');
  const panels = document.querySelectorAll('.fr-panel');

  function activateTab(tabName: string) {
    tabs.forEach(t => t.classList.remove('active'));
    panels.forEach(p => p.classList.remove('active'));
    const targetTab = document.querySelector(`.fr-tab[data-tab="${tabName}"]`);
    const targetPanel = document.getElementById(`tab-${tabName}`);
    if (targetTab) targetTab.classList.add('active');
    if (targetPanel) targetPanel.classList.add('active');
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const tabName = (tab as HTMLElement).dataset.tab;
      if (tabName) {
        activateTab(tabName);
        window.scrollTo({ top: 0, behavior: 'instant' });
      }
    });
  });

  /* ── Hash support ────────────────────────────────────────────────────────── */
  const hash = location.hash.replace('#', '');
  if (hash === 'research') {
    activateTab('research');
  } else if (hash === 'sparring') {
    activateTab('sparring');
  }

  /* ── Deeplink button ─────────────────────────────────────────────────────── */
  const deeplinkBtn = document.getElementById('deeplink-btn');
  if (deeplinkBtn) {
    deeplinkBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        deeplinkBtn.textContent = 'Copied!';
        setTimeout(() => {
          deeplinkBtn.textContent = 'Link';
          deeplinkBtn.style.borderColor = '#21262d';
          deeplinkBtn.style.color = '#6b7280';
        }, 1500);
      });
    });
  }

  /* ── Intensity Slider ───────────────────────────────────────────────────── */
  const zones = [
    {
      min: 0, max: 17,
      name: 'Dead Drilling',
      subtitle: 'No resistance \u00b7 No opponent',
      desc: 'Solo movement, shadow drilling, pre-agreed sequences with no real feedback. Technically useful for motor patterning. Produces no aliveness. The \u6B7B\u529F\u592B condition; the technique may be beautiful and completely fragile on contact with reality.',
      challenge: 'None; environment is fully controlled',
      flow: 'Inaccessible; no challenge to absorb into',
      cognitive: 'Procedural rehearsal',
      color: '#6B7280',
      alert: null
    },
    {
      min: 18, max: 34,
      name: 'Soft Flow Roll',
      subtitle: 'Low resistance \u00b7 Cooperative',
      desc: 'Both partners accommodating. Continuous movement, low stakes. Feels pleasant. Risk: if problem density is also low, this is the comfort zone masquerading as training. Useful for beginners learning movement vocabulary and for injury recovery.',
      challenge: 'Set by partner intention; can be real or fake',
      flow: 'Possible if problem density is maintained',
      cognitive: 'Pattern recognition, low stakes',
      color: '#34D399',
      alert: '\u26a0 ALIVENESS THRESHOLD; below here, resistance is effectively absent. Technique runs on imagined opponents. Useful for beginners. Limited transfer for experienced grapplers without explicit problem-setting intention.'
    },
    {
      min: 35, max: 52,
      name: 'Technical Flow Zone',
      subtitle: 'Modulated resistance \u00b7 Real puzzles',
      desc: 'The highest-value zone for skill development and flow state accessibility. Resistance is genuine but modulated. Partner sets real positional problems (no fake positions, no forgiven posture breaks) at an intensity low enough that the frontal cortex isn\'t saturated by threat response. This is where implicit patterns actually load.',
      challenge: 'Actively set by partner; real, not cooperative fiction',
      flow: 'Most accessible; challenge real, threat absent',
      cognitive: 'Problem-solving \u2192 absorption \u2192 flow state',
      color: '#00FFFF',
      alert: null
    },
    {
      min: 53, max: 67,
      name: 'Ego Threshold Zone',
      subtitle: 'Submission intent enters \u00b7 Cognitive mode shifts',
      desc: 'A qualitative shift, not just a quantitative one. Submission-at-all-cost intention begins to emerge. Both partners start protecting their ego investment. Flow quality often degrades here; movement becomes reactive rather than adaptive. Can still be technically rich, but requires explicit mutual agreement and emotional maturity to maintain problem-density.',
      challenge: 'Opponent is now partly predator, not just puzzle-setter',
      flow: 'Unstable; ego monitors interrupt absorption',
      cognitive: 'Mixed: tactical + threat + self-monitoring',
      color: '#F59E0B',
      alert: '\u26a0 EGO THRESHOLD; submission intent changes the interaction qualitatively. Flow rolling above this line requires explicit mutual agreement. Without it, both partners drift into a different mode. The threshold location is individual and context-dependent.'
    },
    {
      min: 68, max: 79,
      name: 'Hard Flow / Competition Simulation',
      subtitle: 'High resistance \u00b7 Technical intent maintained',
      desc: 'Full-intensity rolling with technical intent preserved. The best competition preparation. Flow state is less accessible but possible for experienced practitioners who have sufficient implicit pattern library to operate without explicit monitoring. Requires significant skill base. Flow here has a different quality; faster, more reactive, less serene.',
      challenge: 'High; opponent fully committed',
      flow: 'Rare; different phenomenology when it occurs',
      cognitive: 'Fast implicit pattern-matching under stress',
      color: '#4C8DFF',
      alert: null
    },
    {
      min: 80, max: 100,
      name: 'Survival Mode',
      subtitle: 'Full threat activation \u00b7 Sympathetic response',
      desc: 'Acute physical threat activates sympathetic nervous system. The context is fundamentally different from the absorption model. Amygdala is triggered, fear-mediated, not flow-mediated. "In the zone" experiences at this level can still be reported retrospectively and have different qualities. Necessary for competition preparation; limited flow state research applies directly.',
      challenge: 'Maximum; survival-oriented',
      flow: 'Different phenomenon; not Csikszentmihalyi\'s model',
      cognitive: 'Threat response dominant',
      color: '#EF4444',
      alert: '\u26a0 THREAT THRESHOLD; sympathetic activation changes what "flow" means. The absorption state described by Csikszentmihalyi was not studied under acute physical threat. Treat reports of "flow" at this level as phenomenologically distinct. Relevant to competition prep; apply the model cautiously.'
    }
  ];

  function getZone(val: number) {
    return zones.find(z => val >= z.min && val <= z.max) || zones[0];
  }

  function render(val: number) {
    const z = getZone(val);
    const fill = document.getElementById('meterFill');
    const pct  = document.getElementById('meterPct');
    const cont = document.getElementById('zoneContent');
    if (!fill || !pct || !cont) return;

    fill.style.height = val + '%';
    fill.style.background = z.color;
    pct.textContent = val + '%';

    cont.innerHTML = `
      <div class="fr-zone-name" style="color:${z.color}">${z.name}</div>
      <div class="fr-zone-subtitle">${z.subtitle}</div>
      <div class="fr-zone-desc">${z.desc}</div>
      <div class="fr-zone-details">
        <div class="fr-detail-cell">
          <div class="fr-d-label">Challenge dynamic</div>
          <div class="fr-d-value">${z.challenge}</div>
        </div>
        <div class="fr-detail-cell">
          <div class="fr-d-label">Flow state accessibility</div>
          <div class="fr-d-value">${z.flow}</div>
        </div>
        <div class="fr-detail-cell">
          <div class="fr-d-label">Cognitive mode</div>
          <div class="fr-d-value">${z.cognitive}</div>
        </div>
      </div>
      ${z.alert ? `<div class="fr-threshold-alert visible" style="border-color:${z.color};color:${z.color}">${z.alert}</div>` : ''}
    `;
  }

  const slider = document.getElementById('intensitySlider') as HTMLInputElement;
  if (slider) {
    slider.addEventListener('input', (e) => render(+(e.target as HTMLInputElement).value));
    render(40);
  }

  /* ── Tab 2: Intersection Observer for section fade-in ─────────────────────── */
  const researchSections = document.querySelectorAll('#tab-research .fr-section');
  const sectionObserver = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.08 });
  researchSections.forEach(s => sectionObserver.observe(s));

  /* ── Tab 2: Condition/Characteristic/Consequence tab toggle ──────────────── */
  document.querySelectorAll('#tab-research .fr-tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tabId = (btn as HTMLElement).dataset.tab;
      document.querySelectorAll('#tab-research .fr-tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('#tab-research .fr-tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      if (tabId) document.getElementById(tabId)?.classList.add('active');
    });
  });

  /* ── Tab 2: 8-Channel Canvas Diagram ─────────────────────────────────────── */
  const channelCanvas = document.getElementById('channelCanvas') as HTMLCanvasElement;
  if (channelCanvas) {
    const cCtx = channelCanvas.getContext('2d')!;
    const cW = channelCanvas.width, cH = channelCanvas.height;

    const channelData = [
      {
        name: 'APATHY',
        desc: 'Low challenge, low skill. The most disengaged state: neither demands nor capabilities are activated. Associated with passivity, lack of interest, and low arousal. Common during passive leisure (TV, waiting).',
        x: 0, y: 2, w: 2, h: 2,
        fill: 'rgba(107,114,128,0.5)', hoverFill: 'rgba(107,114,128,0.7)', stroke: '#4a4a5a'
      },
      {
        name: 'BOREDOM',
        desc: "Low challenge, medium-high skill. The person's capabilities exceed what the task demands. The model predicts dissatisfaction. However, studies have found some individuals report enjoyment and relaxation here \u2014 a key empirical failure of the original channel boundaries.",
        x: 2, y: 2, w: 2, h: 1,
        fill: 'rgba(107,114,128,0.4)', hoverFill: 'rgba(107,114,128,0.6)', stroke: '#4a4a5a'
      },
      {
        name: 'RELAXATION',
        desc: 'Low challenge, high skill. A skilled person doing an easy task. Often comfortable and pleasant \u2014 not the distress the model sometimes implies. Empirically, this channel is frequently conflated with boredom in measurement studies.',
        x: 2, y: 3, w: 2, h: 1,
        fill: 'rgba(52,211,153,0.2)', hoverFill: 'rgba(52,211,153,0.4)', stroke: '#2a6a4a'
      },
      {
        name: 'WORRY',
        desc: 'Medium challenge, low skill. Demands slightly exceed skill but the gap is not extreme. Produces low-level anxiety and self-doubt without the acute distress of the anxiety channel. Often associated with rumination.',
        x: 0, y: 1, w: 1, h: 1,
        fill: 'rgba(239,68,68,0.25)', hoverFill: 'rgba(239,68,68,0.45)', stroke: '#6a3030'
      },
      {
        name: 'ANXIETY',
        desc: 'High challenge, low-medium skill. The largest and most studied non-flow channel. Challenge substantially exceeds skill. Produces distress, performance degradation, and avoidance. The pop model often reduces the entire non-flow space to just this channel.',
        x: 0, y: 0, w: 2, h: 1,
        fill: 'rgba(239,68,68,0.35)', hoverFill: 'rgba(239,68,68,0.55)', stroke: '#8a3030'
      },
      {
        name: 'AROUSAL',
        desc: 'High challenge, medium skill. Demands push beyond current skill but not catastrophically. Associated with heightened attention, mild positive stress, and engagement. Often a precursor to flow as skill develops to meet the challenge.',
        x: 2, y: 0, w: 1, h: 1,
        fill: 'rgba(245,158,11,0.35)', hoverFill: 'rgba(245,158,11,0.55)', stroke: '#7a6020'
      },
      {
        name: 'CONTROL',
        desc: 'Medium-high challenge, high skill. Skill clearly exceeds challenge but the task is still substantive. Produces a sense of mastery and competence. Distinguished from flow by reduced absorption \u2014 the person is competent but not consumed.',
        x: 1, y: 1, w: 2, h: 1,
        fill: 'rgba(76,141,255,0.25)', hoverFill: 'rgba(76,141,255,0.45)', stroke: '#2a4a7a'
      },
      {
        name: 'FLOW',
        desc: 'High challenge, high skill \u2014 balanced. The zone of optimal experience. Challenge and perceived skill are both elevated and matched. Associated with absorption, action-awareness merging, loss of self-consciousness, and transformation of time. The most empirically consistent finding in the literature.',
        x: 3, y: 0, w: 1, h: 2,
        fill: 'rgba(0,255,255,0.3)', hoverFill: 'rgba(0,255,255,0.5)', stroke: '#00FFFF'
      },
    ];

    const COLS = 4, ROWS = 4;
    const cellW = cW / COLS, cellH = cH / ROWS;
    let hoveredChannel: number | null = null;

    function drawCanvasLabels() {
      cCtx.save();
      cCtx.font = '9px "Source Code Pro", "Courier New", monospace';
      cCtx.fillStyle = '#6B7280';

      cCtx.save();
      cCtx.translate(12, cH / 2);
      cCtx.rotate(-Math.PI / 2);
      cCtx.fillText('CHALLENGE \u2192', -30, 0);
      cCtx.restore();

      cCtx.fillStyle = '#4a4a5a';
      cCtx.fillText('LOW', 18, cH - 6);
      cCtx.fillText('HIGH', 18, 14);
      cCtx.restore();
    }

    function drawCanvas() {
      cCtx.clearRect(0, 0, cW, cH);

      channelData.forEach((ch, i) => {
        const px = ch.x * cellW, py = ch.y * cellH;
        const pw = ch.w * cellW, ph = ch.h * cellH;
        const isHov = hoveredChannel === i;

        cCtx.save();
        cCtx.fillStyle = isHov ? ch.hoverFill : ch.fill;
        cCtx.fillRect(px + 1, py + 1, pw - 2, ph - 2);

        cCtx.strokeStyle = isHov ? '#4C8DFF' : ch.stroke;
        cCtx.lineWidth = isHov ? 1.5 : 0.5;
        cCtx.strokeRect(px + 1, py + 1, pw - 2, ph - 2);

        cCtx.font = `${isHov ? '700' : '400'} 9px "Source Code Pro", "Courier New", monospace`;
        cCtx.fillStyle = isHov ? '#00FFFF' : '#9CA3AF';
        cCtx.textAlign = 'center';
        cCtx.textBaseline = 'middle';
        cCtx.fillText(ch.name, px + pw / 2, py + ph / 2);

        cCtx.restore();
      });

      // Flow label decoration
      const fc = channelData[7];
      cCtx.save();
      cCtx.strokeStyle = 'rgba(0,255,255,0.3)';
      cCtx.lineWidth = 1;
      const fx = fc.x * cellW, fy = fc.y * cellH;
      const fw = fc.w * cellW, fh = fc.h * cellH;
      cCtx.strokeRect(fx + 3, fy + 3, fw - 6, fh - 6);
      cCtx.restore();

      drawCanvasLabels();
    }

    function getChannelAt(e: MouseEvent) {
      const rect = channelCanvas.getBoundingClientRect();
      const scaleX = cW / rect.width, scaleY = cH / rect.height;
      const mx = (e.clientX - rect.left) * scaleX;
      const my = (e.clientY - rect.top) * scaleY;
      const col = Math.floor(mx / cellW), row = Math.floor(my / cellH);
      let found: number | null = null;
      channelData.forEach((ch, i) => {
        if (col >= ch.x && col < ch.x + ch.w && row >= ch.y && row < ch.y + ch.h) found = i;
      });
      return found;
    }

    function updateChannelInfo(idx: number | null) {
      const info = document.getElementById('channelInfo');
      if (!info) return;
      if (idx !== null) {
        info.innerHTML = `<div class="ch-name">${channelData[idx].name}</div><div>${channelData[idx].desc}</div>`;
      } else {
        info.innerHTML = '<div class="ch-name">Hover a zone</div><div>Each region represents a distinct psychological state in the original 8-channel model.</div>';
      }
    }

    channelCanvas.addEventListener('mousemove', (e) => {
      const found = getChannelAt(e);
      if (found !== hoveredChannel) {
        hoveredChannel = found;
        drawCanvas();
        updateChannelInfo(found);
      }
    });

    channelCanvas.addEventListener('click', (e) => {
      const found = getChannelAt(e);
      hoveredChannel = found;
      drawCanvas();
      updateChannelInfo(found);
    });

    channelCanvas.addEventListener('mouseleave', () => {
      hoveredChannel = null;
      drawCanvas();
      updateChannelInfo(null);
    });

    drawCanvas();
  }
</script>
