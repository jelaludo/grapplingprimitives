  }
  .fr-threshold-marks {
    position: relative;
    height: 28px;
    margin-top: 0.5rem;
  }
  .fr-t-mark {
    position: absolute;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .fr-t-mark .tick {
    width: 1px;
