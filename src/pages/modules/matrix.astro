---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ConceptMatrix from '@/components/matrix/ConceptMatrix.astro';
import { getCollection } from 'astro:content';

// ── Load data at BUILD TIME ───────────────────────────────────────────────────
const conceptEntries  = await getCollection('concepts');
const categoryEntries = await getCollection('categories');

// Raw axis values in the source data are stored in [0, 1].
// The semantic range for plotting is [-1, 1] (0=Opponent/Physical, 1=Self/Mental).
// Transform:  plotValue = rawValue * 2 - 1
const remap = (v: number) => v * 2 - 1;

// Serialise to plain objects for the canvas script (define:vars must be JSON-safe)
const concepts = conceptEntries.map(e => ({
  id:       e.data.id,
  concept:  e.data.concept,
  category: e.data.category,
  x:        remap(e.data.axis_self_opponent),    // [-1=Opponent … +1=Self]
  y:        remap(e.data.axis_mental_physical),  // [-1=Physical … +1=Mental]
  color:    e.data.color ?? '',
  desc:     e.body ?? '',
  short:    e.data.short_description ?? '',
}));

const categories = categoryEntries.map(e => ({
  name:  e.data.name,
  color: e.data.color,
  xAxis: e.data.xAxis,
  yAxis: e.data.yAxis,
}));
---

<!-- Fullscreen layout — no header padding, immersive canvas -->
<BaseLayout title="Concept Matrix — Grappling Primitives" fullscreen={true}>
  <ConceptMatrix concepts={concepts} categories={categories} />
</BaseLayout>
